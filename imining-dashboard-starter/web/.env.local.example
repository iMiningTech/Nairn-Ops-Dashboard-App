# Copy to .env.local (gitignored). The dashboard reads these at build/runtime.
NEXT_PUBLIC_API_BASE=https://f0nx64v9vc.execute-api.us-east-1.amazonaws.com/prod
# Set only if you enable the API's X-Api-Token (ApiToken param on the API stack):
NEXT_PUBLIC_API_TOKEN=
# PDF render service (deploy Jotform-AWS-API/render → set to its RenderUrl output)
NEXT_PUBLIC_REPORT_API=
# Subscribe service (deploy Jotform-AWS-API/reports → set to its SubscribeUrl output)
NEXT_PUBLIC_SUBSCRIBE_API=
# Preview password gate: SHA-256 hash of the access password. Leave blank to disable
# the gate (open access). Generate: echo -n 'yourpassword' | shasum -a 256 | cut -d" " -f1
NEXT_PUBLIC_ACCESS_HASH=
