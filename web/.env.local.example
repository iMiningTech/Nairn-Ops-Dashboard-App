# Copy to .env.local (gitignored). The dashboard reads these at build/runtime.

# ── Data source ──────────────────────────────────────────────────────────────
# "appsscript" (prod): point at the deployed Apps Script Web App /exec URL.
# "gviz" (dev/zero-backend): read the published Sheet directly as CSV in-browser.
# Leave BASE blank → defaults to gviz so `npm run dev` shows live data with
# nothing deployed.
NEXT_PUBLIC_DATA_MODE=
NEXT_PUBLIC_API_BASE=
# Only if you enable the Apps Script token check (see apps-script/):
NEXT_PUBLIC_API_TOKEN=
# Override the source spreadsheet id (defaults to the Nairn inventory sheet):
NEXT_PUBLIC_SHEET_ID=

# ── Display ──────────────────────────────────────────────────────────────────
# IANA timezone for all displayed timestamps (site time, not the viewer's).
# Nairn Centre, Ontario → America/Toronto.
NEXT_PUBLIC_SITE_TZ=America/Toronto

# Shift start hour (local, 24h) — drives the Overview "start deadtime" tile.
# Operators start at 6am.
NEXT_PUBLIC_SHIFT_START_HOUR=6

# ── Access gate ──────────────────────────────────────────────────────────────
# SHA-256 of the access password. Blank = open (no gate).
# Generate: echo -n 'yourpassword' | shasum -a 256 | cut -d" " -f1
NEXT_PUBLIC_ACCESS_HASH=
